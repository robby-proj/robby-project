docker-compose.yml
services:
  unoq_vision_vlm:
    build:
      context: ./docker
    container_name: unoq_vision_vlm
    restart: unless-stopped
    network_mode: host
    devices:
      - "/dev/video0:/dev/video0"
      - "/dev/video1:/dev/video1"
      - "/dev/video2:/dev/video2"
      - "/dev/video3:/dev/video3"
      - "/dev/snd:/dev/snd"
    group_add:
      - audio
    environment:
      USB_CAMERA_INDEX: "0"
      CAMERA_DEVICE_CANDIDATES: "dev/video2,/dev/video3,/devv/video0,/dev/video1"
      CAPTURE_SECONDS: "3.0"
      FRAME_WIDTH: "640"
      FRAME_HEIGHT: "480"

      YOLO_ONNX_PATH: /models/coco/yolov8n.onnx
      COCO_NAMES_PATH: /models/coco/coco.names
      PERSON_CONFIDENCE: "0.45"
      NMS_THRESHOLD: "0.45"
      INPUT_SIZE: "640"

      YZMA_DIR: /yzma
      YZMA_IMAGES_DIR: /data/images
      VLM_MODEL_PATH: /models/SmolVLM2-500M-Video-Instruct-Q8_0.gguf
      VLM_MMPROJ_PATH: /models/mmproj-SmolVLM2-500M-Video-Instruct-Q8_0.gguf
      VLM_PROMPT: "Look at the person in this image and identify the main color of the top clothing, the main color of the bottom clothing."

      LOG_FILE: /data/logs/vision_web.log
      STATE_FILE: /data/state/vision_web_state.json
      TRIGGER_FILE: /host_tmp/unoq_trigger_detection
      MIN_SECONDS_BETWEEN_TRIGGERS: "5.0"

      AUDIO_PLAYBACK_DEVICE: "plughw:0,0"
      TTS_VOICE: "en-us"
      TTS_SPEED: "155"

    volumes:
      - ./data:/data
      - /home/arduino/yzma:/yzma
      - /home/arduino/models:/models
      - /tmp:/host_tmp
